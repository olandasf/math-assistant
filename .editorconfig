# ═══════════════════════════════════════════════════════════════════
# EDITORCONFIG - Bendri redaktoriaus nustatymai
# Matematikos Mokytojo Asistentas
# ═══════════════════════════════════════════════════════════════════
#
# Šis failas užtikrina vienodus nustatymus visuose redaktoriuose.
# https://editorconfig.org/
#
# ═══════════════════════════════════════════════════════════════════

root = true

# ─────────────────────────────────────────────────────────────────────
# Visiems failams
# ─────────────────────────────────────────────────────────────────────
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# ─────────────────────────────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────────────────────────────
[*.py]
indent_size = 4
max_line_length = 88

# ─────────────────────────────────────────────────────────────────────
# JavaScript / TypeScript / React
# ─────────────────────────────────────────────────────────────────────
[*.{js,jsx,ts,tsx}]
indent_size = 2

# ─────────────────────────────────────────────────────────────────────
# JSON
# ─────────────────────────────────────────────────────────────────────
[*.json]
indent_size = 2

# ─────────────────────────────────────────────────────────────────────
# YAML
# ─────────────────────────────────────────────────────────────────────
[*.{yml,yaml}]
indent_size = 2

# ─────────────────────────────────────────────────────────────────────
# Markdown
# ─────────────────────────────────────────────────────────────────────
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# ─────────────────────────────────────────────────────────────────────
# HTML / CSS
# ─────────────────────────────────────────────────────────────────────
[*.{html,css}]
indent_size = 2

# ─────────────────────────────────────────────────────────────────────
# SQL
# ─────────────────────────────────────────────────────────────────────
[*.sql]
indent_size = 2

# ─────────────────────────────────────────────────────────────────────
# Shell scripts
# ─────────────────────────────────────────────────────────────────────
[*.{sh,bash}]
indent_size = 2
end_of_line = lf

# ─────────────────────────────────────────────────────────────────────
# PowerShell
# ─────────────────────────────────────────────────────────────────────
[*.{ps1,psm1,psd1}]
indent_size = 4
end_of_line = crlf

# ─────────────────────────────────────────────────────────────────────
# Makefile (turi būti tabs!)
# ─────────────────────────────────────────────────────────────────────
[Makefile]
indent_style = tab
