# ═══════════════════════════════════════════════════════════════════
# MATEMATIKOS MOKYTOJO ASISTENTAS - APLINKOS KINTAMIEJI
# ═══════════════════════════════════════════════════════════════════
# 
# INSTRUKCIJA:
# 1. Nukopijuokite šį failą kaip .env
# 2. Užpildykite reikalingas reikšmes
# 3. Niekada necommitinkite .env failo į Git!
#
# ═══════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────
# APLIKACIJOS NUSTATYMAI
# ─────────────────────────────────────────────────────────────────────

# Aplikacijos pavadinimas
APP_NAME=Matematikos Asistentas

# Aplinka: development, staging, production
APP_ENV=development

# Debug režimas (true/false)
DEBUG=true

# ─────────────────────────────────────────────────────────────────────
# DUOMENŲ BAZĖ
# ─────────────────────────────────────────────────────────────────────

# SQLite duomenų bazės kelias (reliatyvus nuo backend folderio)
DATABASE_URL=sqlite:///./database/matematika.db

# ─────────────────────────────────────────────────────────────────────
# MATHPIX API (Matematikos OCR)
# ─────────────────────────────────────────────────────────────────────
# Registracija: https://mathpix.com/
# Kaina: ~$0.01-0.05/puslapis, 100 nemokamai/mėn

MATHPIX_APP_ID=
MATHPIX_APP_KEY=

# ─────────────────────────────────────────────────────────────────────
# GOOGLE CLOUD
# ─────────────────────────────────────────────────────────────────────
# Registracija: https://console.cloud.google.com/
# Reikia įjungti: Cloud Vision API

# Kelias iki Google Cloud credentials JSON failo
GOOGLE_APPLICATION_CREDENTIALS=./credentials/google-cloud.json

# Google Cloud projekto ID
GOOGLE_PROJECT_ID=

# ─────────────────────────────────────────────────────────────────────
# GOOGLE GEMINI API (AI/NLP)
# ─────────────────────────────────────────────────────────────────────
# Registracija: https://aistudio.google.com/
# Kaina: Nemokamas limitas pradžioje

GEMINI_API_KEY=

# ─────────────────────────────────────────────────────────────────────
# WOLFRAMALPHA API (Matematikos tikrinimas)
# ─────────────────────────────────────────────────────────────────────
# Registracija: https://developer.wolframalpha.com/
# Kaina: 2000 nemokamų užklausų/mėn

WOLFRAM_APP_ID=

# ─────────────────────────────────────────────────────────────────────
# OCR NUSTATYMAI
# ─────────────────────────────────────────────────────────────────────

# Numatytasis OCR metodas: local, hybrid, full
DEFAULT_OCR_METHOD=hybrid

# Tesseract kelias (Windows)
TESSERACT_PATH=C:/Program Files/Tesseract-OCR/tesseract.exe

# ─────────────────────────────────────────────────────────────────────
# FAILŲ ĮKĖLIMAS
# ─────────────────────────────────────────────────────────────────────

# Maksimalus failo dydis (bytes) - 50MB
MAX_UPLOAD_SIZE=52428800

# Įkeltų failų folderis
UPLOAD_DIR=./uploads

# Leidžiami failų formatai
ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf

# ─────────────────────────────────────────────────────────────────────
# PDF NUSTATYMAI
# ─────────────────────────────────────────────────────────────────────

# PDF šablonų folderis
PDF_TEMPLATE_DIR=./templates/pdf

# ─────────────────────────────────────────────────────────────────────
# FRONTEND
# ─────────────────────────────────────────────────────────────────────

# Backend API URL (naudojamas frontend)
VITE_API_URL=http://localhost:8000/api/v1

# ─────────────────────────────────────────────────────────────────────
# SAUGUMAS
# ─────────────────────────────────────────────────────────────────────

# Secret key JWT tokenams (sugeneruokite unikalų!)
# Generuoti: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ─────────────────────────────────────────────────────────────────────
# DEVELOPMENT
# ─────────────────────────────────────────────────────────────────────

# CORS allowed origins (atskirti kableliais)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ═══════════════════════════════════════════════════════════════════
# PASTABOS:
# 
# 1. Pradžioje pakanka užpildyti tik:
#    - GEMINI_API_KEY (nemokamas)
#    - WOLFRAM_APP_ID (2000 nemokamų/mėn)
#    
# 2. MathPix ir Google Cloud galima pridėti vėliau
#
# 3. Lokalūs OCR (Tesseract, EasyOCR) veikia be API raktų
#
# ═══════════════════════════════════════════════════════════════════
