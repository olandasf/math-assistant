# ═══════════════════════════════════════════════════════════════════
# MATH TEACHER ASSISTANT - ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════════════════════
# 
# INSTRUCTIONS:
# 1. Copy this file as .env
# 2. Fill in the required values
# 3. NEVER commit the .env file to Git!
#
# ═══════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────
# APPLICATION SETTINGS
# ─────────────────────────────────────────────────────────────────────

# Application name
APP_NAME=Matematikos Asistentas

# Environment: development, staging, production
APP_ENV=development

# Debug mode (true/false)
DEBUG=true

# ─────────────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────────────

# SQLite database path (relative to backend folder)
DATABASE_URL=sqlite:///./database/matematika.db

# ─────────────────────────────────────────────────────────────────────
# GOOGLE GEMINI API (Required - AI Vision OCR + Explanations)
# ─────────────────────────────────────────────────────────────────────
# Sign up: https://aistudio.google.com/
# Cost: Free tier available

GEMINI_API_KEY=

# ─────────────────────────────────────────────────────────────────────
# WOLFRAMALPHA API (Recommended - Math Verification)
# ─────────────────────────────────────────────────────────────────────
# Sign up: https://developer.wolframalpha.com/
# Cost: 2000 free requests/month

WOLFRAM_APP_ID=

# ─────────────────────────────────────────────────────────────────────
# OPENAI API (Optional - Alternative OCR Provider)
# ─────────────────────────────────────────────────────────────────────
# Sign up: https://platform.openai.com/
# Note: Can also be configured via the app settings UI

# OPENAI_API_KEY=

# ─────────────────────────────────────────────────────────────────────
# NOVITA AI (Optional - Alternative OCR Provider)
# ─────────────────────────────────────────────────────────────────────
# Sign up: https://novita.ai/
# Note: Can also be configured via the app settings UI

# NOVITA_API_KEY=

# ─────────────────────────────────────────────────────────────────────
# FILE UPLOADS
# ─────────────────────────────────────────────────────────────────────

# Max file size (bytes) - 50MB
MAX_UPLOAD_SIZE=52428800

# Upload directory
UPLOAD_DIR=./uploads

# Allowed file extensions
ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf

# ─────────────────────────────────────────────────────────────────────
# PDF SETTINGS
# ─────────────────────────────────────────────────────────────────────

# PDF template directory
PDF_TEMPLATE_DIR=./templates/pdf

# ─────────────────────────────────────────────────────────────────────
# FRONTEND
# ─────────────────────────────────────────────────────────────────────

# Backend API URL (used by frontend)
VITE_API_URL=http://localhost:8000/api/v1

# ─────────────────────────────────────────────────────────────────────
# SECURITY
# ─────────────────────────────────────────────────────────────────────

# Secret key for JWT tokens (generate a unique one!)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ─────────────────────────────────────────────────────────────────────
# DEVELOPMENT
# ─────────────────────────────────────────────────────────────────────

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ═══════════════════════════════════════════════════════════════════
# GETTING STARTED:
# 
# 1. Required: GEMINI_API_KEY (free tier at aistudio.google.com)
# 2. Recommended: WOLFRAM_APP_ID (2000 free/month)
# 3. Optional: OPENAI_API_KEY, NOVITA_API_KEY (alternative OCR)
#
# OCR providers can also be configured through the web UI settings.
# ═══════════════════════════════════════════════════════════════════
